SECRET_KEY=__RANDOM_KEY__
DOMAIN_NAME=__DOMAIN__
DATABASE_URL=postgresql://__DB_USER__:__DB_PWD__@127.0.0.1:5432/__DB_NAME__
ENVIRONMENT=production
LOG_LEVEL=INFO
DEBUG=false
MEDIA_ROOT=__DATA_DIR__
MAX_FILE_SIZE_MB=100
DISABLE_SIGNUP=false
LOG_DIR="/var/log/__APP__"

# Django cache via redis
REDIS_URL=redis://localhost:6379/__REDIS_DB__
# Celery message queue
CELERY_BROKER_URL=redis://localhost:6379/__CELERY_DB__
# Celery task results
CELERY_RESULT_BACKEND=redis://localhost:6379/__CELERY_DB__
